  "description": "AXTELL FAN - Industrial ceiling and mobile fans website",
  "type": "module",
  "main": "dist/index.js",
  "homepage": "https://my-wordpress-fan.vercel.app",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
